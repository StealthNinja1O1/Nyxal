# Port the Elysia API + WebSocket server listens on.
NYXAL_PORT=3000

# SQLite database file path (created automatically).
NYXAL_DB_PATH=./data/nyxal.db

# How long to keep persisted runtime logs (days).
NYXAL_LOG_RETENTION_DAYS=30

# Number of recent log lines restored to a client on WS connect.
NYXAL_LOG_HISTORY=500
